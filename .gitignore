node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── React build output ────────────────────────────────────────
frontend/build/
frontend/.env.local
frontend/.env.production.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
.Python

